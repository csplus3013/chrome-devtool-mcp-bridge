FROM node:22-slim

RUN apt-get update -q \
    && apt-get install -y --no-install-recommends curl procps \
    && rm -rf /var/lib/apt/lists/*

# Pre-install chrome-devtools-mcp so `docker exec` starts instantly (no npx cold-start)
RUN npm install -g chrome-devtools-mcp@latest

# Keep container alive — the AI agent spawns chrome-devtools-mcp via `docker exec -i`
CMD ["sleep", "infinity"]
